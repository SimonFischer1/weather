<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Simon Fischer Wetterportal</title>

style.css

https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css

https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap

https://api.windy.com/assets/map-forecast/libBoot.jsscript>

</head>
<body>

<header>
    <div class="banner">
        BANNER
    </div>

    <div class="login">
        <i class="fa-solid fa-user"></i>
    </div>
</header>

<div class="separator"></div>

<main>

    <section class="weather-box">
        <h2>🌧 Regenradar</h2>
        <div id="radar"></div>
    </section>

    <section class="weather-box">
        <h2>💨 Windkarte</h2>
        <div id="wind"></div>
    </section>

    <section class="weather-box">
        <h2>🇩🇪 DWD Bodenwetterkarte</h2>

        https://www.dwd.de/DWD/wetter/wv_allg/deutschland/bwk_bodendruck_na_ana.png
        </iframe>

    </section>

</main>

<div class="separator"></div>

<section class="ais-section">

    <h2>🚢 Live AIS Schiffsverkehr</h2>

    https://www.vesselfinder.com/aismap?zoom=6&lat=53.14&lon=8.46
    </iframe>

</section>

<div class="separator"></div>

<section class="links">

    <div class="link-card">
        <h3>Text1</h3>
        #Link1</a>
    </div>

    <div class="link-card">
        <h3>Text2</h3>
        #Link2</a>
    </div>

    <div class="link-card">
        <h3>Text3</h3>
        #Link3</a>
    </div>

    <div class="link-card">
        <h3>Text4</h3>
        #Link4</a>
    </div>

    <div class="link-card">
        <h3>Text5</h3>
        #Link5</a>
    </div>

    <div class="link-card">
        <h3>Text6</h3>
        #Link6</a>
    </div>

</section>

<div class="separator"></div>

<footer>

    <div class="heart">
        ❤️ Simon Fischer
    </div>

    <div class="copyright">
        © Simon Fischer
    </div>

</footer>

script.jsscript>

</body>
</html>
